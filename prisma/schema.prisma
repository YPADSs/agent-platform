generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Locale {
  EN
  FR
  DE
  ES
  IT
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PantryItemSource {
  MANUAL
  SHOPPING_LIST
  PLANNER
}

model User {
  id               String @id @default(cuid())
  email            String @unique
  passwordHash     String
  role             Role   @default(USER)

  // Stripe linkage (optional until first checkout)
  stripeCustomerId String? @unique

  subscription Subscription?
  preferences  UserPreferences?
  mealPlans    MealPlan[]

  favorites     Favorite[]
  shoppingItems ShoppingListItem[]
  pantryItems   PantryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPreferences {
  id                    String           @id @default(cuid())
  userId                String           @unique
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  goalCode              String?
  locale                Locale           @default(EN)
  unitSystem            UnitSystem       @default(METRIC)
  onboardingStatus      OnboardingStatus @default(NOT_STARTED)
  onboardingCompletedAt DateTime?

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model BillingEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  receivedAt    DateTime @default(now())
  processedAt   DateTime?
}

model Recipe {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  body          String
  mealPlanItems MealPlanItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FavoriteTargetType {
  RECIPE
  ARTICLE
}

model Favorite {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetType FavoriteTargetType
  targetSlug String

  createdAt  DateTime           @default(now())

  @@unique([userId, targetType, targetSlug])
}

model ShoppingListItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text      String
  checked   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngredientCatalog {
  id                        String                       @id @default(cuid())
  key                       String                       @unique
  defaultName               String
  categoryKey               String?
  pantryItems               PantryItem[]
  outgoingSubstitutionRules IngredientSubstitutionRule[] @relation("SubstitutionSourceIngredient")
  incomingSubstitutionRules IngredientSubstitutionRule[] @relation("SubstitutionTargetIngredient")

  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  @@index([categoryKey])
}

model PantryItem {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      IngredientCatalog @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  quantity        Decimal?          @db.Decimal(10, 2)
  unit            String?
  source          PantryItemSource  @default(MANUAL)
  sourceRefId     String?
  displayName     String?
  note            String?
  lastConfirmedAt DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, ingredientId])
  @@index([userId, updatedAt])
  @@index([ingredientId])
  @@index([source, sourceRefId])
}

model IngredientSubstitutionRule {
  id                     String             @id @default(cuid())
  sourceIngredientId     String?
  sourceIngredient       IngredientCatalog? @relation("SubstitutionSourceIngredient", fields: [sourceIngredientId], references: [id], onDelete: Restrict)
  sourceCategoryKey      String?
  substituteIngredientId String
  substituteIngredient   IngredientCatalog  @relation("SubstitutionTargetIngredient", fields: [substituteIngredientId], references: [id], onDelete: Restrict)
  sortOrder              Int                @default(1)
  reason                 String
  note                   String?
  isActive               Boolean            @default(true)

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([sourceIngredientId, isActive, sortOrder])
  @@index([sourceCategoryKey, isActive, sortOrder])
  @@index([substituteIngredientId])
  @@index([isActive, sortOrder])
}

model MealPlan {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  items         MealPlanItem[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, weekStartDate])
}

model MealPlanItem {
  id         String    @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  planDate   DateTime
  slot       MealSlot
  slotIndex  Int       @default(1)
  recipeId   String
  recipe     Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  servings   Int       @default(1)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([mealPlanId, planDate, slot, slotIndex])
}
